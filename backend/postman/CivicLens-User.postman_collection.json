              "mode": "raw",
              "raw": "{\n  \"title\": \"Overflowing garbage bins near Central Market\",\n  \"description\": \"Three municipal bins have been overflowing for two days, causing foul smell and stray animals gathering in the lane.\",\n  \"category\": \"MUNICIPAL_SERVICES\",\n  \"type\": \"ISSUE\",\n  \"location\": {\n    \"city\": \"Mumbai\",\n    \"lat\": 19.0760,\n    \"lng\": 72.8777\n  }\n}"
            },
